# --- App ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=4040
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres_test?sslmode=disable

# --- Logging ---
LOG_FORMAT=json   # or "pretty" for colorized stdout in dev

# --- OpenTelemetry → SigNoz (self-hosted defaults) ---
OTEL_SERVICE_NAME=gokit
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317        # gRPC: traces, metrics, logs
OTEL_EXPORTER_OTLP_HTTP_ENDPOINT=http://localhost:4318  # HTTP: Genkit plugin only
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_ARG=1.0   # 1.0 = sample all (dev); 0.1 = 10% (prod)

# Set service.instance.id in your shell/orchestrator, not here — godotenv does
# NOT expand ${VARS}. Example: export OTEL_RESOURCE_ATTRIBUTES="deployment.environment=dev,service.instance.id=$(hostname)"
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev

# --- SigNoz Cloud (uncomment + replace if using cloud) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=ingest.us.signoz.cloud:443
# OTEL_EXPORTER_OTLP_INSECURE=false
# OTEL_EXPORTER_OTLP_HEADERS=signoz-ingestion-key=YOUR_KEY_HERE
